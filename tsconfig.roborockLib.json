{
  "compilerOptions": {
    "target": "ES2018",
    "module": "commonjs",
    "lib": ["es2018"],
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "moduleResolution": "node",
    "types": ["node"],
    "skipLibCheck": true,
    "maxNodeModuleJsDepth": 0
  },
  "include": ["roborockLib/lib/messageQueueHandler.js"],
  "exclude": ["node_modules"]
}
